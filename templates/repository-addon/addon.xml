<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.kodi-mcp"
       name="Kodi MCP Repository"
       version="{{repo_version}}"
       provider-name="Kodi MCP">
    <extension point="xbmc.addon.repository" name="Kodi MCP Repository">
        <dir>
            <info compressed="false">{{repo_base_url}}/repo/content/addons.xml</info>
            <checksum>{{repo_base_url}}/repo/content/addons.xml.md5</checksum>
            <datadir zip="true">{{repo_base_url}}/repo/content/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Kodi MCP Repository</summary>
        <description>Repository for Kodi MCP server addons and packages</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
    <asset>
        <icon>icon.png</icon>
    </asset>
</addon>
