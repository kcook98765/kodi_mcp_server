# Kodi MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Kodi JSON-RPC endpoint URL
# Example: http://kodi.local:8080/jsonrpc
KODI_JSONRPC_URL=

# Required: Base URL of the Kodi bridge addon
# Example: http://kodi.local:8080 (or the bridge's actual URL)
KODI_BRIDGE_BASE_URL=

# Optional (Milestone A): shared token for authenticated bridge endpoints
# MUST match Kodi addon setting: service.kodi_mcp → mcp_token
# Required for protected bridge endpoints when the addon token is set.
# Health/status/capabilities remain readable; control, screenshot, logs, staging,
# addon execution, and file endpoints require this token.
KODI_BRIDGE_TOKEN=

# Optional: Kodi JSON-RPC authentication (if enabled)
KODI_JSONRPC_USERNAME=
KODI_JSONRPC_PASSWORD=

# Optional: Request timeout in seconds (default: 10)
KODI_TIMEOUT=10

# Optional: TCP host for WebSocket notifications (auto-detected from KODI_JSONRPC_URL if not set)
KODI_TCP_HOST=

# Optional: TCP port for WebSocket notifications (default: 9090)
KODI_TCP_PORT=9090

# Optional: WebSocket URL for notifications (optional, used for notification probing)
KODI_WEBSOCKET_URL=

# Optional: Repo server host (default: 0.0.0.0)
REPO_SERVER_HOST=0.0.0.0

# Optional: Repo server port (default: 8001)
REPO_SERVER_PORT=8001

# Required for Kodi/repo/addon install URLs when server and Kodi are on separate hosts.
# Must be reachable from Kodi and from clients that need served screenshots.
REPO_BASE_URL=http://server.local:8010

# Optional: server-side screenshot storage and cleanup.
KODI_SCREENSHOT_STORE_DIR=
KODI_SCREENSHOT_RETENTION_SECONDS=3600
KODI_SCREENSHOT_MAX_FILES=100

# Optional: vision model. If either value is blank, no vision-analysis tools are exposed.
KODI_VISION_MODEL_URL=
KODI_VISION_MODEL_NAME=
